<?xml version="1.0" encoding="utf-8"?>
<!-- item_option_text.xml - Opsi teks untuk pertanyaan tipe TEXT_ONLY -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/option_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:background="@drawable/bg_option_text_unselected"
    android:layout_marginBottom="8dp">

    <View
        android:id="@+id/radio_circle"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:background="@drawable/radio_circle_unselected" />

    <TextView
        android:id="@+id/tv_option_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_dark" />
</LinearLayout>
