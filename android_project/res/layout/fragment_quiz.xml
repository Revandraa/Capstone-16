<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_quiz.xml - Halaman kuis (container dinamis per pertanyaan) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header: Back Button + Title -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_circle_gray"
            android:src="@drawable/ic_arrow_left"
            android:scaleType="centerInside"
            android:contentDescription="Kembali"
            android:padding="8dp" />

        <TextView
            android:id="@+id/tv_quiz_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="Pertanyaan 1"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_dark" />
    </LinearLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:paddingHorizontal="20dp">

        <!-- Pink Card Container -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/light_pink"
            app:cardCornerRadius="40dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="25dp"
                android:gravity="center_horizontal"
                android:minHeight="580dp">

                <!-- Question Title -->
                <TextView
                    android:id="@+id/tv_question_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textColor="@color/text_dark"
                    android:lineSpacingMultiplier="1.4"
                    android:textAlignment="center"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp" />

                <!-- Note (opsional, ditampilkan untuk pertanyaan 1-4) -->
                <TextView
                    android:id="@+id/tv_question_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/text_gray"
                    android:textAlignment="textStart"
                    android:visibility="gone"
                    android:layout_marginBottom="20dp" />

                <!-- Dynamic Options Container (diisi secara programatis) -->
                <!-- Untuk GRID: GridLayout 2 kolom dengan gambar -->
                <!-- Untuk TEXT_ONLY: LinearLayout vertical dengan radio options -->
                <LinearLayout
                    android:id="@+id/options_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- AI Upload Section (hanya untuk non-noAI questions) -->
                <LinearLayout
                    android:id="@+id/ai_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginTop="25dp"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="2dp"
                        android:background="#FFD5D5"
                        android:layout_marginBottom="20dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🤖 Opsi AI MobileNet"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_red"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:id="@+id/ai_dropzone"
                        android:layout_width="match_parent"
                        android:layout_height="140dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_dashed_border"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:src="@drawable/ic_camera"
                            android:tint="@color/primary_red"
                            android:contentDescription="Camera"
                            android:layout_marginBottom="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Unggah Foto Organ Ini"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Biar AI MobileNet yang mendeteksi gejala"
                            android:textSize="12sp"
                            android:textColor="@color/text_gray" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Spacer -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Navigation: Prev + Progress + Next -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="30dp">

                    <ImageButton
                        android:id="@+id/btn_prev"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_chevron_left"
                        android:contentDescription="Sebelumnya"
                        android:scaleType="centerInside" />

                    <!-- Progress Bar -->
                    <ProgressBar
                        android:id="@+id/progress_bar"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="15dp"
                        android:max="100"
                        android:progress="11"
                        android:progressDrawable="@drawable/progress_bar_drawable" />

                    <ImageButton
                        android:id="@+id/btn_next"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="Selanjutnya"
                        android:scaleType="centerInside" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </ScrollView>
</LinearLayout>
