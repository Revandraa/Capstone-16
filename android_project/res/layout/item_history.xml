<?xml version="1.0" encoding="utf-8"?>
<!-- item_history.xml - Item riwayat diagnosa -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="15dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="@drawable/history_item_border">

        <!-- Thumbnail -->
        <ImageView
            android:id="@+id/iv_thumb"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/pmk_monitor_logo"
            android:scaleType="centerCrop"
            android:background="#EEEEEE"
            android:contentDescription="Thumbnail" />

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:orientation="vertical">

            <!-- Type Badge -->
            <TextView
                android:id="@+id/tv_type_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manual AHP"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_badge_gray"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:layout_marginBottom="6dp" />

            <!-- Rate -->
            <TextView
                android:id="@+id/tv_rate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="95% Harapan Hidup"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_red" />

            <!-- Date -->
            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10 Jun 2026"
                android:textSize="12sp"
                android:textColor="@color/text_gray" />
        </LinearLayout>

        <!-- Chevron -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_chevron_right"
            android:tint="@color/primary_red"
            android:contentDescription="Detail" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
