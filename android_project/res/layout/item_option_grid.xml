<?xml version="1.0" encoding="utf-8"?>
<!-- item_option_grid.xml - Opsi gambar untuk pertanyaan tipe GRID (2 kolom) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- Radio + Label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <View
            android:id="@+id/radio_circle"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/radio_circle_unselected" />

        <TextView
            android:id="@+id/tv_option_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="12sp"
            android:textColor="@color/text_dark" />
    </LinearLayout>

    <!-- Image -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="15dp"
        app:cardElevation="0dp">

        <ImageView
            android:id="@+id/iv_option_image"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:background="#CCCCCC"
            android:contentDescription="Option Image" />
    </androidx.cardview.widget.CardView>
</LinearLayout>
