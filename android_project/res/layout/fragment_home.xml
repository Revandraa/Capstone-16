<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_home.xml - Halaman beranda PMK Monitor -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Top Row: Logo + Brand + Logout -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/pmk_monitor_logo"
                    android:scaleType="centerCrop"
                    android:contentDescription="Logo" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:text="PMK Monitor"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark" />

                <ImageButton
                    android:id="@+id/btn_logout"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_circle_gray"
                    android:src="@drawable/ic_logout"
                    android:scaleType="centerInside"
                    android:contentDescription="Logout"
                    android:padding="8dp" />
            </LinearLayout>

            <!-- Welcome Text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Halo, Peternak! 👋"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Sistem Pemantauan Harapan Hidup &amp; Indikasi Suspek PMK Sapi berbasis Hybrid AI + AHP"
                android:textSize="13sp"
                android:textColor="@color/text_gray"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Main Card (pink background) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="20dp"
            app:cardBackgroundColor="@color/light_pink"
            app:cardCornerRadius="40dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="25dp"
                android:gravity="center_horizontal">

                <!-- Logo Image -->
                <ImageView
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:src="@drawable/pmk_monitor_logo"
                    android:scaleType="centerCrop"
                    android:layout_marginBottom="20dp"
                    android:contentDescription="PMK Monitor Logo" />

                <!-- Description -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Dapatkan persentase tingkat indikasi suspek PMK secara akurat melalui kuesioner cerdas terpadu (opsional pilih ganda atau unggah foto AI per gejala)."
                    android:textSize="15sp"
                    android:textColor="@color/text_dark"
                    android:lineSpacingMultiplier="1.6"
                    android:textAlignment="center"
                    android:layout_marginBottom="25dp"
                    android:paddingHorizontal="15dp" />

                <!-- Menu Card: Mulai Deteksi PMK -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_start_quiz"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="22dp">

                        <!-- Icon -->
                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_rounded_pink"
                            android:layout_marginBottom="14dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_cpu"
                                android:tint="@color/primary_red"
                                android:contentDescription="CPU Icon" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mulai Deteksi PMK"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kuesioner Hybrid AI MobileNet &amp; Manual AHP dalam satu alur praktis"
                            android:textSize="13sp"
                            android:textColor="@color/text_gray"
                            android:lineSpacingMultiplier="1.4"
                            android:layout_marginBottom="12dp" />

                        <!-- Badge -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HYBRID SYSTEM"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:background="@drawable/bg_badge_red"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Menu Card: Riwayat Diagnosa -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="22dp">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_rounded_gray"
                            android:layout_marginBottom="14dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_calendar"
                                android:tint="@color/text_gray"
                                android:contentDescription="Calendar Icon" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Riwayat Diagnosa"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_dark"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lihat kembali hasil diagnosa dan persentase tingkat suspek PMK sapi Anda"
                            android:textSize="13sp"
                            android:textColor="@color/text_gray"
                            android:lineSpacingMultiplier="1.4" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
